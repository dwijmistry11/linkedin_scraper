# Twenty CRM Configuration
# Copy this to .env and fill in values

# REQUIRED: Security secret — generate with: openssl rand -base64 32
APP_SECRET=

# REQUIRED: PostgreSQL password (avoid special characters like @, #, !)
PG_DATABASE_PASSWORD=

# REQUIRED: External URL where Twenty CRM is accessible
# For local development: http://localhost:3000
# For production: https://crm.yourdomain.com
SERVER_URL=http://localhost:3000

# File storage: "local" (default) or "s3"
STORAGE_TYPE=local

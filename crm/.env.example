# Twenty CRM Configuration
# Copy this to .env and fill in values

# ── Core ──────────────────────────────────────────────────────────────

# REQUIRED: Security secret — generate with: openssl rand -base64 32
APP_SECRET=

# REQUIRED: External URL where Twenty CRM is accessible
SERVER_URL=https://crm.yourdomain.com

# ── AWS RDS (PostgreSQL) ──────────────────────────────────────────────

RDS_HOST=your-instance.xxxx.ap-south-1.rds.amazonaws.com
RDS_PORT=5432
RDS_DATABASE=postgres
RDS_USERNAME=postgres
RDS_PASSWORD=

# ── AWS S3 (File Storage) ─────────────────────────────────────────────

AWS_REGION=ap-south-1
S3_BUCKET_NAME=your-twenty-crm-bucket
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# S3_ENDPOINT=  # Only for S3-compatible services (MinIO, DigitalOcean Spaces)

# ── Redis ──────────────────────────────────────────────────────────────

# Local Redis (bundled in docker-compose.yml)
REDIS_URL=redis://twenty-redis-local:6379

# ── Email (SMTP) ──────────────────────────────────────────────────────

EMAIL_DRIVER=smtp
# Microsoft Outlook / Office 365:
EMAIL_SMTP_HOST=smtp.office365.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your@company.com
EMAIL_SMTP_PASSWORD=
# Gmail alternative:
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USER=your@gmail.com
# EMAIL_SMTP_PASSWORD=<app-password>

# ── Security (uncomment AFTER creating admin account) ──────────────────

# IS_MULTIWORKSPACE_ENABLED=false
# IS_WORKSPACE_CREATION_LIMITED_TO_SERVER_ADMINS=true
# LOGIC_FUNCTION_TYPE=DISABLED
# CODE_INTERPRETER_TYPE=DISABLED

# ── Microsoft SSO + Sync (optional) ───────────────────────────────────

# AUTH_MICROSOFT_ENABLED=true
# AUTH_MICROSOFT_CLIENT_ID=
# AUTH_MICROSOFT_CLIENT_SECRET=
# AUTH_MICROSOFT_CALLBACK_URL=https://crm.yourdomain.com/auth/microsoft/redirect
# AUTH_MICROSOFT_APIS_CALLBACK_URL=https://crm.yourdomain.com/auth/microsoft-apis/get-access-token
# MESSAGING_PROVIDER_MICROSOFT_ENABLED=true
# CALENDAR_PROVIDER_MICROSOFT_ENABLED=true

# ── Google SSO + Sync (optional) ──────────────────────────────────────

# AUTH_GOOGLE_CLIENT_ID=
# AUTH_GOOGLE_CLIENT_SECRET=
# AUTH_GOOGLE_CALLBACK_URL=https://crm.yourdomain.com/auth/google/redirect
# AUTH_GOOGLE_APIS_CALLBACK_URL=https://crm.yourdomain.com/auth/google-apis/get-access-token
# MESSAGING_PROVIDER_GMAIL_ENABLED=true
# CALENDAR_PROVIDER_GOOGLE_ENABLED=true

# ── Local Development Only ─────────────────────────────────────────────
# Used by docker-compose.local.yml (bundled PostgreSQL)
PG_DATABASE_PASSWORD=

# Twenty CRM Configuration
# Copy this to .env and fill in values

# ── Core ──────────────────────────────────────────────────────────────

# REQUIRED: Security secret — generate with: openssl rand -base64 32
APP_SECRET=

# REQUIRED: External URL where Twenty CRM is accessible
SERVER_URL=https://crm.yourdomain.com

# ── AWS RDS (PostgreSQL) ──────────────────────────────────────────────

RDS_HOST=your-instance.xxxxxxxxxxxx.us-east-1.rds.amazonaws.com
RDS_PORT=5432
RDS_DATABASE=twenty
RDS_USERNAME=twenty
RDS_PASSWORD=

# ── AWS S3 (File Storage) ─────────────────────────────────────────────

AWS_REGION=us-east-1
S3_BUCKET_NAME=your-twenty-crm-bucket
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# S3_ENDPOINT=  # Only set for S3-compatible services (MinIO, DigitalOcean Spaces, etc.)

# ── Redis ──────────────────────────────────────────────────────────────

# For AWS ElastiCache:
# REDIS_URL=redis://your-cluster.xxxx.cache.amazonaws.com:6379
# For local Redis (bundled in docker-compose.yml):
REDIS_URL=redis://twenty-redis-local:6379

# ── Local Development Only ─────────────────────────────────────────────
# Used by docker-compose.local.yml (bundled PostgreSQL)
PG_DATABASE_PASSWORD=
